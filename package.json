{
  "name": "smart-pos",
  "version": "1.0.0",
  "description": "نقطة البيع الذكية - Smart POS System",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run server\" \"vite\" \"wait-on http://localhost:5173 && wait-on http://localhost:3001/api/settings && cross-env electron .\"",
    "build": "vite build",
    "server": "tsx server/index.ts",
    "start": "concurrently -k \"npm run server\" \"vite\"",
    "electron": "electron .",
    "build:exe": "vite build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.smartpos.app",
    "productName": "Smart POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "server/**/*",
      ".env",
      "!server/**/*.ts",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/tsx",
        "to": "node_modules/tsx"
      }
    ],
    "win": {
      "target": "portable",
      "icon": null
    },
    "portable": {
      "artifactName": "Smart-POS.exe"
    },
    "asar": false
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "lucide-react": "^0.344.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "sql.js": "^1.10.3",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  }
}
