{
  "name": "smart-pos",
  "version": "2.0.0",
  "description": "Smart POS System - نقطة البيع الذكية",
  "author": {
    "name": "Smart POS",
    "email": "support@smartpos.app"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run server\" \"vite\" \"wait-on http://localhost:5173 && wait-on http://localhost:3001/api/settings && cross-env electron .\"",
    "build": "vite build",
    "server": "tsx server/index.ts",
    "server:build": "node node_modules/esbuild/bin/esbuild server/index.ts --bundle --platform=node --target=node18 --outfile=server-build/index.js --format=cjs",
    "start": "concurrently -k \"npm run server\" \"vite\"",
    "electron": "electron .",
    "build:exe": "npm run server:build && vite build && electron-builder --win nsis",
    "build:portable": "npm run server:build && vite build && electron-builder --win portable",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.smartpos.app",
    "productName": "Smart POS",
    "copyright": "Copyright © 2025 Smart POS",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "server-build/**/*",
      ".env",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Smart-POS-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smart POS",
      "runAfterFinish": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName": "Smart-POS-Setup-${version}.exe",
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "ar",
        "en"
      ],
      "language": "1025",
      "include": null,
      "license": null
    },
    "portable": {
      "artifactName": "Smart-POS-Portable.exe"
    },
    "asar": true,
    "asarUnpack": [
      "server-build/**/*"
    ]
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@zxing/browser": "^0.2.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "multer": "^1.4.5-lts.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "sql.js": "^1.10.3",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  }
}
