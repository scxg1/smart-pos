# ─── Authentication ──────────────────────────────────────────────────────────
# Override the default JWT signing secret. Generate a strong random value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-secret

# ─── AI / Z.AI ───────────────────────────────────────────────────────────────
# Z.AI (GLM) API key — required for the AI assistant feature
ZAI_API_KEY=your-zai-api-key-here

# ─── Data Storage ────────────────────────────────────────────────────────────
# Override where the SQLite database and uploads are stored.
# Defaults to <project-root>/data and <project-root>/uploads when unset.
# DATA_DIR=C:/ProgramData/SmartPOS
